# =============================================================================
# GEKO Magazine Web App - Variabili Ambiente
# =============================================================================
#
# Copia questo file in .env e configura i valori:
#   cp .env.example .env
#
# =============================================================================

# -----------------------------------------------------------------------------
# Claude API (opzionale)
# -----------------------------------------------------------------------------
# API key per generazione sommari automatici con Claude.
# Se non impostata, i sommari saranno placeholder.
# Ottieni una key su: https://console.anthropic.com/
#
ANTHROPIC_API_KEY=sk-ant-api...

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------
# development: debug attivo, reload automatico
# production: ottimizzato per produzione
#
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# MCP / Scalekit (OAuth 2.1 per client Claude)
# -----------------------------------------------------------------------------
SCALEKIT_ENVIRONMENT_URL=https://<org>.scalekit.com
SCALEKIT_CLIENT_ID=skc_...
SCALEKIT_CLIENT_SECRET=...
SCALEKIT_RESOURCE_ID=res_...
MCP_PUBLIC_URL=https://geko-mcp.fabris.me
# Opzionale: override dell'Authorization Server annunciato nel discovery
# SCALEKIT_AUTHORIZATION_SERVER=https://<org>.scalekit.com/resources/res_...
